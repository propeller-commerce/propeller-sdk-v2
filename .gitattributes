# Normalize all text to LF in the repository, regardless of contributor OS or
# core.autocrlf. Without this, the build-generated files under
# src/generated/** (written with LF by scripts/build-graphql-bundle.js) show as
# modified on every Windows checkout — pure line-ending noise that defeats the
# content-based drift guard (scripts/check-generated-drift.js).
* text=auto eol=lf

# Generated — keep LF, collapse in diffs/reviews, exclude from language stats.
src/generated/**      linguist-generated=true
documentation/**      linguist-generated=true
schema.json           linguist-generated=true

# Binary / non-diffable.
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.ico   binary
*.woff  binary
*.woff2 binary
